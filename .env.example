# --- Whisper model ---------------------------------------------------------
# Recommended: large-v3 (best quality) or large-v3-turbo (≈ 8x faster, slight quality drop)
WHISPER_MODEL=large-v3

# auto | cuda | cpu
WHISPER_DEVICE=auto

# auto | float16 | int8_float16 | int8 | float32
# float16 on GPU, int8 on CPU is the typical sweet spot.
WHISPER_COMPUTE_TYPE=auto

# Where to cache downloaded model weights (mount a Docker volume here).
WHISPER_DOWNLOAD_ROOT=/models

# Load the model at boot (1 = fast first request, slower startup).
WHISPER_PRELOAD=1

# Background worker count for /transcribe/async. Each worker uses GPU memory.
WHISPER_ASYNC_WORKERS=1

# --- Limits ----------------------------------------------------------------
# Max multipart upload size (MB)
MAX_UPLOAD_MB=2048

# Max remote URL download size (MB)
WHISPER_MAX_DOWNLOAD_SIZE_MB=2048

# Remote URL download timeouts (seconds)
WHISPER_DOWNLOAD_CONNECT_TIMEOUT=15
WHISPER_DOWNLOAD_TIMEOUT=600

# --- Server ----------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WAITRESS_THREADS=4
# Allow long-running requests (1h). Bump higher for very long audios.
WAITRESS_CHANNEL_TIMEOUT=3600

LOG_LEVEL=INFO
